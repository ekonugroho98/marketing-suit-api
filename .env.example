# ============================================
# Karaya API - Environment Variables
# ============================================

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# --- Supabase (service role — NEVER expose to client) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Must match TOKEN_ENCRYPTION_KEY used by Supabase Edge Functions
# 64 hex chars (32 bytes) — AES-256-GCM
TOKEN_ENCRYPTION_KEY=

# --- AI Providers ---
# Built-in Groq key (used when provider=groq or legacy calls)
GROQ_API_KEY=gsk_...

# --- CORS (comma-separated, or * for any) ---
ALLOWED_ORIGINS=*

# --- Rate limit (global safety net, per-key limit stored in DB) ---
GLOBAL_MAX_RPM=600
